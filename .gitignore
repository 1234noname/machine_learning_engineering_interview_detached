.pytype/

# Cython debug symbols
cython_debug/

# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# PyPI configuration file
.pypirc

# Research library — kept locally for reference, not committed.
reading/

# Harness worktrees — isolated checkouts created per issue by harness/run.sh.
worktrees/
# Harness run artifacts (ndjson logs, diffs, summaries) — large and ephemeral;
# keeping them untracked prevents reviewer diffs from ballooning 100×.
harness/runs/*/

# Elixir/Mix — fetched at build time, never committed.
apps/*/deps/
apps/*/_build/
libs/*/deps/
libs/*/_build/
erl_crash.dump

# Terraform — local state, plan files, and tfvars containing real values.
# `*.tfvars.example` and `backend.tfvars.example` ARE committed (templates).
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/terraform.tfvars
infra/terraform/**/backend.tfvars
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.*
infra/terraform/**/*.tfplan
infra/terraform/**/backend_ci_override.tf
.env

# Node.js / pnpm — installed at build time, never committed.
node_modules/

# Next.js — build output and cache.
.next/
*.tsbuildinfo

# OpenAPI-generated TypeScript types — regenerated by CI and pre-commit hook.
frontend/packages/shared/src/generated.ts
frontend/apps/shopper/test-results

# macOS metadata files.
.DS_Store

# AVSA storage backend root. Runtime-generated bytes stay ignored; the seed
# datasets (Fashion200k images, #062 embedding artifact, attribute heads) are
# committed via Git LFS (.gitattributes) and pulled by `just setup` (#090).
/data/*
!/data/fashion200k/
# Track only the committed #062 artifact + #067 heads, not future runtime-
# regenerated hash dirs under these trees (security review #090): descend into
# the tree, re-ignore its contents, then un-ignore the one committed hash dir.
!/data/embeddings/
/data/embeddings/*
!/data/embeddings/7decaeecdc769a1a4ab2e758684f740c5607bef0c07e9ac3cc027936f25cb899/
!/data/attribute_heads/
/data/attribute_heads/*
!/data/attribute_heads/e8bcf7394f30b59124167d70b14a7283e28aa614e40e567284c0a8295c2db2de/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# AVSA — generated config (avsa.toml is produced by `just config-gen <env>` from
# avsa.base.toml + an environment overlay; never committed directly).
config/avsa.toml

# AVSA — per-run benchmark sweep outputs. Timestamped bench-*.json files
# accumulate on every `just capture-baseline` / `bench-qps` run and are never
# committed. baseline.json / frontier.json are also runtime artifacts (derived
# from bench runs) and are not committed.
evals/qps/**/bench-*.json
evals/qps/**/baseline.json
evals/qps/**/frontier.json
# MCP discovery session log — ephemeral, not committed.
evals/mcp/discovery-session.json
# Fashion200k catalog checksum — regenerated by seed script, not committed.
evals/catalog/fashion200k/inputs-sha256.txt

# C extensions
*.so


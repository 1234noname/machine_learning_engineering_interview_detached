#!/usr/bin/env bash
# AVSA project-tracked pre-commit hook.
#
# Tiny wrapper that delegates to pre-commit (https://pre-commit.com) so the
# hook is portable — no machine-specific paths to embed (which is why we
# can't use pre-commit's own autogenerated script under core.hooksPath).
# Requires `pre-commit` on PATH (installed by `just setup` via Brewfile).
set -euo pipefail
exec pre-commit run --hook-stage pre-commit

# avsa.local.env.example — LOCAL-REAL stack environment variable reference
#
# Copy this file to .env at the repo root and fill in your values:
#   cp config/avsa.local.env.example .env
#   $EDITOR .env
#
# .env is gitignored (see .gitignore) — NEVER commit secret values.
# This example file lists VARIABLE NAMES ONLY; no values are included.
#
# Issue #072 — local-real stack bring-up
# See docs/runbooks/local-real-stack.md for the full runbook.

# ── Required for real LLM (AVSA.LLM.Anthropic) ────────────────────────────────
# Anthropic API key used by the orchestrator when AVSA_LLM_STUB is unset.
# Obtain from https://console.anthropic.com/settings/keys
# A single real /chat turn costs ~$0.001–$0.01 depending on context length.
AVSA_ANTHROPIC_API_KEY=

# ── Required for image storage HMAC signing ────────────────────────────────────
# HMAC secret used by the API to sign and verify storage URLs.
# Generate with: openssl rand -hex 32
AVSA_STORAGE_HMAC_SECRET=

# ── Optional overrides (defaults shown; usually leave unset) ───────────────────

# Set to "1" to use the mock LLM (AVSA.LLM.Mock) instead of Anthropic.
# Useful when running without an API key or to avoid LLM costs during
# model-only smoke runs. The smoke script assertion #3 will skip if set.
# Default: unset (real LLM)
# AVSA_LLM_STUB=1

# Set to "1" to use the stub model service instead of real ViT.
# Default: 0 (real model) when started via `just stack-up`
# AVSA_MODEL_STUB=1

# Override the Postgres connection URL.
# Default: postgresql://avsa:avsa@localhost:5434/avsa
# DATABASE_URL=postgresql://avsa:avsa@localhost:5434/avsa
